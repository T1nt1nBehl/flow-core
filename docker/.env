# =============================================================================
# FlowCore — Shared Environment Variables
# Referenced by all docker-compose.*.yml files.
# Copy to docker/.env and edit before first run. Never commit secrets.
# =============================================================================

# ── Project ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=flowcore

# ── Persistent stores (docker-compose.yml) ───────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=flowcore
PG_PASSWORD=flowcore_secret
PG_DB=flowcore

TS_HOST=timescaledb
TS_PORT=5432
TS_USER=flowcore
TS_PASSWORD=flowcore_secret
TS_DB=flowcore_ts

NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=flowcore_secret

# ── Kafka / Redpanda (docker-compose.kafka.yml) ───────────────────────────────
KAFKA_BROKER=kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
REDPANDA_KAFKA_PORT=9092          # host-exposed Kafka port
REDPANDA_SCHEMA_PORT=8081         # Schema Registry (inside platform container)
REDPANDA_ADMIN_PORT=9644          # Redpanda admin API (internal)
REDPANDA_UI_PORT=8090             # Kafka UI — host exposed

# ── Platform container (docker-compose.platform.yml) ─────────────────────────
# Schema Registry
SCHEMA_REGISTRY_URL=http://platform:8081

# Keycloak
KEYCLOAK_PORT=8080                # host-exposed
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_REALM=flowcore
KEYCLOAK_CLIENT_ID=flowcore-app
KEYCLOAK_CLIENT_SECRET=flowcore-client-secret

# Ingestion services (internal ports inside platform container)
DCIM_INGESTION_PORT=8001
TELEMETRY_GATEWAY_HTTP_PORT=8002
TELEMETRY_GATEWAY_UDP_PORT=9999
ACTIVE_DISCOVERY_PORT=8003
GRAPH_UPDATER_PORT=8010
TIMESERIES_WRITER_PORT=8011
EVENT_ARCHIVE_PORT=8012

# S3-compatible object store (MinIO or local path for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=flowcore-archive
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── API + UI container (docker-compose.api.yml) ───────────────────────────────
API_GATEWAY_PORT=8888             # nginx proxy — single host-exposed port
GRAPH_API_INTERNAL_PORT=4000      # GraphQL
INSIGHTS_API_INTERNAL_PORT=4001   # REST
EVENTING_API_INTERNAL_PORT=4002   # REST
NOC_FRONTEND_INTERNAL_PORT=3000   # Vite / React

# JWT validation
JWT_ISSUER=http://localhost:8080/realms/flowcore
JWT_AUDIENCE=flowcore-app

# ── Agents container (docker-compose.agents.yml) ──────────────────────────────
TOPO_AGENT_PORT=8020
CLASS_AGENT_PORT=8021
MLFLOW_PORT=5000                  # host-exposed MLflow UI
MLFLOW_TRACKING_URI=http://agents:5000

# ── Synthetic replay (docker-compose.replay.yml) ──────────────────────────────
REPLAY_PORT=8050                  # health + control REST API
REPLAY_MODE=live                  # live | historical
REPLAY_EVENTS_PER_SEC=1000        # rate for live mode (max 50000 for NFR-06 test)
REPLAY_HISTORICAL_SPEED=60        # historical: 1 real second = N simulated seconds

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
