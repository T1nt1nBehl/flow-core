# =============================================================================
# FlowCore — Agents Container
# Services: topology-reconciliation-agent + classification-capability-agent + MLflow
# Build context: flowcore/ root
# =============================================================================

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    wget curl build-essential libgomp1 supervisor \
    && rm -rf /var/lib/apt/lists/*

# ML + agent dependencies (libgomp1 required for LightGBM)
RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    "uvicorn[standard]==0.30.0" \
    pydantic==2.7.0 \
    pydantic-settings==2.3.0 \
    confluent-kafka==2.4.0 \
    asyncpg==0.29.0 \
    neo4j==5.20.0 \
    mlflow==2.13.0 \
    lightgbm==4.3.0 \
    scikit-learn==1.5.0 \
    "numpy>=1.26,<2" \
    python-dotenv==1.0.1 \
    "setuptools<75"

RUN mkdir -p \
    /app/topology-reconciliation-agent \
    /app/classification-capability-agent \
    /var/log/supervisord \
    /mlflow/db \
    /mlflow/artifacts

COPY services/topology-agent/       /app/topology-reconciliation-agent/
COPY services/classification-agent/ /app/classification-capability-agent/
COPY docker/supervisord/agents.conf /etc/supervisor/conf.d/agents.conf

EXPOSE 5000 8020 8021

CMD ["supervisord", "-n", "-c", "/etc/supervisor/conf.d/agents.conf"]
