# =============================================================================
# FlowCore — Master Environment File
# All compose files source from this single .env
# Copy to the same directory you run docker compose from (flowcore/deploy/)
# =============================================================================

# ── Project ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=flowcore

# ── Persistent stores (from docker-compose.stores.yml) ───────────────────────
POSTGRES_HOST=flowcore-postgres
POSTGRES_PORT=5432
POSTGRES_DB=flowcore
POSTGRES_USER=flowcore
POSTGRES_PASSWORD=flowcore_secret

TIMESCALE_HOST=flowcore-timescaledb
TIMESCALE_PORT=5433
TIMESCALE_DB=flowcore_ts
TIMESCALE_USER=flowcore
TIMESCALE_PASSWORD=flowcore_secret

NEO4J_HOST=flowcore-neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=flowcore_secret

# ── Kafka (docker-compose.kafka.yml) ─────────────────────────────────────────
KAFKA_BOOTSTRAP=flowcore-kafka:9092
KAFKA_EXTERNAL_PORT=9092
KAFKA_UI_PORT=8090
REDPANDA_ADMIN_PORT=9644

# ── Platform container (docker-compose.platform.yml) ─────────────────────────
SCHEMA_REGISTRY_PORT=8081
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_REALM=flowcore

DCIM_INGESTION_PORT=8001
TELEMETRY_GATEWAY_PORT=8002
TELEMETRY_GATEWAY_UDP_PORT=9999
ACTIVE_DISCOVERY_PORT=8003
GRAPH_UPDATER_PORT=8010
TIMESERIES_WRITER_PORT=8011
EVENT_ARCHIVE_PORT=8012

S3_ENDPOINT=http://flowcore-minio:9000
S3_ACCESS_KEY=flowcore
S3_SECRET_KEY=flowcore_secret
S3_BUCKET=flowcore-events

# ── API container (docker-compose.api.yml) ────────────────────────────────────
API_GATEWAY_PORT=8000
GRAPH_API_INTERNAL_PORT=4000
INSIGHTS_API_INTERNAL_PORT=4001
EVENTING_INTEGRATION_INTERNAL_PORT=4002
NOC_FRONTEND_INTERNAL_PORT=3000

# ── Agents container (docker-compose.agents.yml) ──────────────────────────────
TOPOLOGY_AGENT_PORT=8020
CLASSIFICATION_AGENT_PORT=8021
MLFLOW_PORT=5000

# ── Synthetic replay (docker-compose.replay.yml) ──────────────────────────────
REPLAY_MODE=live
REPLAY_EVENTS_PER_SEC=1000
REPLAY_PORT=8030

# ── Shared JWT secret (dev only — use Keycloak in any real environment) ───────
JWT_SECRET=flowcore-dev-jwt-secret-change-in-prod
