{
  "realm": "flowcore",
  "displayName": "FlowCore",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "NOC_OPERATOR",
        "description": "Read-only access + alert/classification feedback"
      },
      {
        "name": "CHANGE_MANAGER",
        "description": "NOC_OPERATOR + create and run what-if simulations"
      },
      {
        "name": "DC_ADMIN",
        "description": "CHANGE_MANAGER + write entity attributes + approve drift suggestions"
      },
      {
        "name": "PLATFORM_ADMIN",
        "description": "Full access including tenant management and source system configuration"
      }
    ]
  },
  "clients": [
    {
      "clientId": "flowcore-ui",
      "name": "FlowCore NOC Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "flowcore-api",
      "name": "FlowCore API Services",
      "enabled": true,
      "publicClient": false,
      "secret": "flowcore-api-secret",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "noc.operator",
      "email": "noc.operator@flowcore.local",
      "firstName": "NOC",
      "lastName": "Operator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "noc123", "temporary": false }],
      "realmRoles": ["NOC_OPERATOR"]
    },
    {
      "username": "change.manager",
      "email": "change.manager@flowcore.local",
      "firstName": "Change",
      "lastName": "Manager",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "change123", "temporary": false }],
      "realmRoles": ["CHANGE_MANAGER"]
    },
    {
      "username": "dc.admin",
      "email": "dc.admin@flowcore.local",
      "firstName": "DC",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "dcadmin123", "temporary": false }],
      "realmRoles": ["DC_ADMIN"]
    },
    {
      "username": "platform.admin",
      "email": "platform.admin@flowcore.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "platform123", "temporary": false }],
      "realmRoles": ["PLATFORM_ADMIN"]
    }
  ]
}
